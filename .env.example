# OpenForge Configuration Overrides
# Set these to override config.yaml values

# Server
OPENFORGE_SERVER_HOST=127.0.0.1
OPENFORGE_SERVER_PORT=9090

# Models
OPENFORGE_MODELS_PATH=./models
OPENFORGE_MODELS_DEFAULT=
OPENFORGE_MODELS_DEVICE=auto

# Cache
OPENFORGE_CACHE_ENABLED=true
OPENFORGE_CACHE_BACKEND=memory

# Logging
OPENFORGE_LOGGING_LEVEL=info
OPENFORGE_LOGGING_FORMAT=json

# Telemetry
OPENFORGE_TELEMETRY_ENABLED=false
